# Backend env vars — copy to apps/api/.env (gitignored)

# AI providers (at least one required for /api/chat)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# CORS — comma-separated origins allowed in production
CORS_ORIGINS=http://localhost:3000

# Snapshot file path (relative to repo root)
SNAPSHOT_PATH=reports/trades_snapshot_latest.json

# Cache TTL for snapshot reads (seconds)
SNAPSHOT_CACHE_TTL=300

# Auth (production only — leave blank for dev)
API_KEY=
