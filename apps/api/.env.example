# Backend env vars — copy to apps/api/.env (gitignored)

# AI providers (at least one required for /api/chat)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# CORS — comma-separated origins allowed in production
CORS_ORIGINS=http://localhost:3000

# Snapshot file path (relative to repo root)
SNAPSHOT_PATH=reports/trades_snapshot_latest.json

# Google Drive snapshot source (production secrets; compact JSON, never commit real values)
GDRIVE_FILE_ID=1RIXpDUIq1692_6UwoPFYyrKtukYB2UArCTWvI6Y5Xbk
GDRIVE_CREDENTIALS_JSON=
GDRIVE_TOKEN_JSON=

# Cache TTL for snapshot reads (seconds)
SNAPSHOT_CACHE_TTL=300

# Auth (production only — leave blank for dev)
API_KEY=

# Snapshot scheduler — auto-runs export_control_panel.py on a cron.
# Default OFF. Set to 1 in production (and locally if you want auto-refresh).
SCHEDULER_ENABLED=0
# Every N minutes during the cron window
SCHEDULER_INTERVAL_MIN=10
# Cron hour and day-of-week ranges (APScheduler CronTrigger syntax)
SCHEDULER_HOURS=9-16
SCHEDULER_DAYS=mon-fri
# IANA timezone — uses tzdata for Windows
SCHEDULER_TZ=America/New_York
