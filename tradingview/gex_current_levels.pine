//@version=5
// =======================================================================
// GEX Current Levels - AUTO-GENERATED
// For use on DAILY or HOURLY charts.
// DO NOT EDIT MANUALLY. Regenerate every Monday via:
//   python scripts/gex_input.py --week YYYY-MM-DD
// Last updated : 2026-04-14
// Week         : 2026-04-07
// =======================================================================
indicator("GEX Current Levels", overlay=true, max_labels_count=50, shorttitle="GEX Now")

// --- FILTERS --------------------------------------------------------
var string G = "Filter"
show_gflip = input.bool(true,  "Gamma Flip",                 group=G)
show_pos   = input.bool(true,  "Call Walls (Positive GEX)",  group=G)
show_neg   = input.bool(true,  "Put Support (Negative GEX)", group=G)
show_agg   = input.bool(false, "Aggregate / Confluence",      group=G)

// --- INPUTS (Colors) ------------------------------------------------
var string _GC = "Colors"
C_GFLIP = input.color(color.white,                           "Gamma Flip",   group=_GC, display=display.none)
C_POS   = input.color(color.rgb(0, 200, 83),                 "Positive GEX", group=_GC, display=display.none)
C_NEG   = input.color(color.rgb(255, 23, 68),                "Negative GEX", group=_GC, display=display.none)
C_AGG   = input.color(color.rgb(170, 0, 255),                "Aggregate",    group=_GC, display=display.none)
C_PZ    = input.color(color.new(color.rgb(0, 200, 83),  45), "Pos Zone",     group=_GC, display=display.none)
C_NZ    = input.color(color.new(color.rgb(255, 23, 68), 45), "Neg Zone",     group=_GC, display=display.none)

// Only draw on SPY-scale charts (excludes SPX > 2000)
_valid = close < 2000

// Levels visible from this week's Monday onwards
_in_week = time >= 1775568600000 and _valid

// --- PRICE LEVELS via plot() ----------------------------------------
// plot() is stable on zoom/scroll/symbol change; color inputs work correctly.
plot(show_gflip and _in_week ? 662.0 : na, "g-flip ($662)", color=C_GFLIP, style=plot.style_linebr, linewidth=2)
plot(show_pos and _in_week ? 670.0 : na, "p ($670)", color=C_POS, style=plot.style_linebr, linewidth=2)
plot(show_pos and _in_week ? 665.0 : na, "p ($665)", color=C_POS, style=plot.style_linebr, linewidth=2)
plot(show_pos and _in_week ? 661.0 : na, "p3 ($661)", color=C_POS, style=plot.style_linebr, linewidth=2)
plot(show_pos and _in_week ? 660.0 : na, "p1+coi+ag2 ($660)", color=C_POS, style=plot.style_linebr, linewidth=2)
plot(show_pos and _in_week ? 657.0 : na, "p2 ($657)", color=C_POS, style=plot.style_linebr, linewidth=2)
plot(show_neg and _in_week ? 651.0 : na, "low gex ($651)", color=C_NEG, style=plot.style_linebr, linewidth=2)
plot(show_neg and _in_week ? 650.0 : na, "n+ag spike ($650)", color=C_NEG, style=plot.style_linebr, linewidth=2)
plot(show_neg and _in_week ? 645.0 : na, "n+ag spike ($645)", color=C_NEG, style=plot.style_linebr, linewidth=2)
plot(show_agg and _in_week ? 656.0 : na, "ag3 ($656)", color=C_AGG, style=plot.style_linebr, linewidth=2)
plot(show_agg and _in_week ? 654.0 : na, "ag4 ($654)", color=C_AGG, style=plot.style_linebr, linewidth=2)
plot(show_neg and _in_week ? 655.0 : na, "ag+neg gex starts ($655)", color=C_NZ, style=plot.style_linebr, linewidth=2)

// --- LABELS via label.new() -----------------------------------------
_label_off = timeframe.in_seconds(timeframe.period) * 10000
var label[] _B = array.new_label()
if barstate.islast and _valid
    for lb in _B
        label.delete(lb)
    array.clear(_B)
    _lbl = timenow + _label_off
    if show_gflip
        array.push(_B, label.new(_lbl, 662.0, "g-flip ($662)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_GFLIP, style=label.style_none, size=size.small))
    if show_pos
        array.push(_B, label.new(_lbl, 670.0, "p ($670)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
    if show_pos
        array.push(_B, label.new(_lbl, 665.0, "p ($665)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
    if show_pos
        array.push(_B, label.new(_lbl, 661.0, "p3 ($661)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
    if show_pos
        array.push(_B, label.new(_lbl, 660.0, "p1+coi+ag2 ($660)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
    if show_pos
        array.push(_B, label.new(_lbl, 657.0, "p2 ($657)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
    if show_neg
        array.push(_B, label.new(_lbl, 651.0, "low gex ($651)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
    if show_neg
        array.push(_B, label.new(_lbl, 650.0, "n+ag spike ($650)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
    if show_neg
        array.push(_B, label.new(_lbl, 645.0, "n+ag spike ($645)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
    if show_agg
        array.push(_B, label.new(_lbl, 656.0, "ag3 ($656)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_AGG, style=label.style_none, size=size.small))
    if show_agg
        array.push(_B, label.new(_lbl, 654.0, "ag4 ($654)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_AGG, style=label.style_none, size=size.small))
    if show_neg
        array.push(_B, label.new(_lbl, 655.0, "ag+neg gex starts ($655)", xloc=xloc.bar_time, color=color.new(color.black, 100), textcolor=C_NZ, style=label.style_none, size=size.small))
