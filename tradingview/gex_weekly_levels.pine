            float _p1_ndx_5 = 26540.0
            if (SH_N2) and not na(_p1_ndx_5)
                array.push(_lines, line.new(_bi1, _p1_ndx_5, _bi1 + W, _p1_ndx_5, color=C_N2, style=f_style(STY_N2), width=LW_N2))
