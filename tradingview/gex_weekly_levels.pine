        f_draw_level(_t1, _t2, 675.0, C_N1, STY_N1, LW_N1, (SH_N1 or SH_N2 or SH_N3), "n2 ($" + str.tostring(math.round(675.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 670.0, C_N1, STY_N1, LW_N1, (SH_N1 or SH_N2 or SH_N3), "n1 + poi ($" + str.tostring(math.round(670.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 660.0, C_N1, STY_N1, LW_N1, (SH_N1 or SH_N2 or SH_N3), "n + hoi ($" + str.tostring(math.round(660.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))

