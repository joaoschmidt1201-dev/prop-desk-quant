//@version=5
// =======================================================================
// GEX Weekly Levels [TradingLitt Style] — SPX + NDX — AUTO-GENERATED
// DO NOT EDIT MANUALLY. Regenerate via:
//   python scripts/gex_csv_parser.py <csv_path> --week YYYY-MM-DD
// Last updated : 2026-04-20
// Weeks stored : 2
// =======================================================================
indicator("GEX Weekly Levels [TradingLitt]", overlay=true, max_lines_count=500, max_labels_count=500, shorttitle="GEX Levels")

// --- TICKER DETECTION -----------------------------------------------
_is_spx = syminfo.ticker == "SPX" or str.contains(syminfo.ticker, "ES1")
_is_ndx = syminfo.ticker == "NDX" or str.contains(syminfo.ticker, "NQ1")
_valid  = _is_spx or _is_ndx

// --- INPUTS (Colors) ------------------------------------------------
var string _GC = "Colors"
C_GFLIP = input.color(color.rgb(128, 0, 200),                "Gamma Flip",   group=_GC, display=display.none)
C_POS   = input.color(color.rgb(0, 200, 83),                 "Positive GEX", group=_GC, display=display.none)
C_NEG   = input.color(color.rgb(255, 23, 68),                "Negative GEX", group=_GC, display=display.none)
C_AGG   = input.color(color.rgb(170, 0, 255),                "Aggregate",    group=_GC, display=display.none)
C_SEP_W = color.new(color.gray, 40)
C_SEP_D = color.new(color.gray, 72)

// --- INPUTS (Styles) ------------------------------------------------
var string _GS = "Styles"
STY_GFLIP = input.string("Dashed",  "Gamma Flip",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_P1    = input.string("Solid",   "Pos GEX p1",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_P2    = input.string("Dashed",  "Pos GEX p2",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_P3    = input.string("Dotted",  "Pos GEX p3",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_N1    = input.string("Solid",   "Neg GEX n1",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_N2    = input.string("Dashed",  "Neg GEX n2",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_N3    = input.string("Dotted",  "Neg GEX n3",   options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)
STY_AGG   = input.string("Dotted",  "Aggregate",    options=["Solid", "Dashed", "Dotted"], group=_GS, display=display.none)

f_style(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed

// True on the first 15m bar of a given Monday (by timestamp)
is_week_start(ts) => time >= ts and (na(time[1]) or time[1] < ts)

// 15m chart: 26 bars/day, 130 bars/week
W = 130
D = 26

// --- MONDAY BAR INDEX DETECTION (auto-generated) --------------------
var int _bi0 = na
var int _bi1 = na

if is_week_start(1776087000000) and _valid
    _bi0 := bar_index
if is_week_start(1776691800000) and _valid
    _bi1 := bar_index

// --- GLOBAL LINE / LABEL STORAGE ------------------------------------
var line[]  _lines  = array.new_line()
var label[] _labels = array.new_label()

// --- REDRAW ON LAST BAR (delete all → redraw with current inputs) ---
if barstate.islast and _valid
    for l in _lines
        line.delete(l)
    array.clear(_lines)
    for lb in _labels
        label.delete(lb)
    array.clear(_labels)
    // --- Week 0: 2026-04-13 ---
    if not na(_bi0)
        array.push(_lines, line.new(_bi0, close, _bi0, close + 1, color=C_SEP_W, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi0 + D, close, _bi0 + D, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi0 + D * 2, close, _bi0 + D * 2, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi0 + D * 3, close, _bi0 + D * 3, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        float _p0_0 = _is_spx ? 6667.0 : 23825.0
        if not na(_p0_0)
            array.push(_lines, line.new(_bi0, _p0_0, _bi0 + W, _p0_0, color=C_GFLIP, style=f_style(STY_GFLIP), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_0, "g-flip " + str.tostring(math.round(_p0_0)) + (_is_spx ? " ★" : " ★"), color=color.new(color.black, 100), textcolor=C_GFLIP, style=label.style_none, size=size.small))
        float _p0_1 = _is_spx ? 7000.0 : 25900.0
        if not na(_p0_1)
            array.push(_lines, line.new(_bi0, _p0_1, _bi0 + W, _p0_1, color=C_POS, style=f_style(STY_P1), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_1, "p1 + agg " + str.tostring(math.round(_p0_1)) + (_is_spx ? " ★" : " ★"), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p0_2 = _is_spx ? 6900.0 : 25300.0
        if not na(_p0_2)
            array.push(_lines, line.new(_bi0, _p0_2, _bi0 + W, _p0_2, color=C_POS, style=f_style(STY_P2), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_2, "p2 " + str.tostring(math.round(_p0_2)) + (_is_spx ? "" : " ★"), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p0_3 = _is_spx ? 7100.0 : 25700.0
        if not na(_p0_3)
            array.push(_lines, line.new(_bi0, _p0_3, _bi0 + W, _p0_3, color=C_POS, style=f_style(STY_P3), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_3, "p3 " + str.tostring(math.round(_p0_3)) + (_is_spx ? " ★" : ""), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p0_4 = _is_spx ? 6800.0 : 24500.0
        if not na(_p0_4)
            array.push(_lines, line.new(_bi0, _p0_4, _bi0 + W, _p0_4, color=C_NEG, style=f_style(STY_N1), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_4, "n1 " + str.tostring(math.round(_p0_4)) + (_is_spx ? " ★" : ""), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
        float _p0_5 = _is_spx ? 6700.0 : 24800.0
        if not na(_p0_5)
            array.push(_lines, line.new(_bi0, _p0_5, _bi0 + W, _p0_5, color=C_NEG, style=f_style(STY_N2), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_5, "n2 " + str.tostring(math.round(_p0_5)) + (_is_spx ? "" : " ★"), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
        float _p0_6 = _is_spx ? 6755.0 : 24000.0
        if not na(_p0_6)
            array.push(_lines, line.new(_bi0, _p0_6, _bi0 + W, _p0_6, color=C_NEG, style=f_style(STY_N3), width=2))
            array.push(_labels, label.new(_bi0 + W, _p0_6, "n3 " + str.tostring(math.round(_p0_6)) + (_is_spx ? "" : " ★"), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))

    // --- Week 1: 2026-04-20 ---
    if not na(_bi1)
        array.push(_lines, line.new(_bi1, close, _bi1, close + 1, color=C_SEP_W, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi1 + D, close, _bi1 + D, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi1 + D * 2, close, _bi1 + D * 2, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        array.push(_lines, line.new(_bi1 + D * 3, close, _bi1 + D * 3, close + 1, color=C_SEP_D, style=line.style_dashed, width=1, extend=extend.both))
        float _p1_0 = _is_spx ? 6625.0 : 25700.0
        if not na(_p1_0)
            array.push(_lines, line.new(_bi1, _p1_0, _bi1 + W, _p1_0, color=C_GFLIP, style=f_style(STY_GFLIP), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_0, "g-flip " + str.tostring(math.round(_p1_0)) + (_is_spx ? " ★" : ""), color=color.new(color.black, 100), textcolor=C_GFLIP, style=label.style_none, size=size.small))
        float _p1_1 = _is_spx ? 7050.0 : 25850.0
        if not na(_p1_1)
            array.push(_lines, line.new(_bi1, _p1_1, _bi1 + W, _p1_1, color=C_POS, style=f_style(STY_P1), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_1, "p1 + agg " + str.tostring(math.round(_p1_1)) + (_is_spx ? " ★" : " ★"), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p1_2 = _is_spx ? 7200.0 : 25750.0
        if not na(_p1_2)
            array.push(_lines, line.new(_bi1, _p1_2, _bi1 + W, _p1_2, color=C_POS, style=f_style(STY_P2), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_2, "p2 " + str.tostring(math.round(_p1_2)) + (_is_spx ? " ★" : " ★"), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p1_3 = _is_spx ? 7100.0 : 26250.0
        if not na(_p1_3)
            array.push(_lines, line.new(_bi1, _p1_3, _bi1 + W, _p1_3, color=C_POS, style=f_style(STY_P3), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_3, "p3 " + str.tostring(math.round(_p1_3)) + (_is_spx ? "" : ""), color=color.new(color.black, 100), textcolor=C_POS, style=label.style_none, size=size.small))
        float _p1_4 = _is_spx ? 6800.0 : 26080.0
        if not na(_p1_4)
            array.push(_lines, line.new(_bi1, _p1_4, _bi1 + W, _p1_4, color=C_NEG, style=f_style(STY_N1), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_4, "n1 " + str.tostring(math.round(_p1_4)) + (_is_spx ? " ★" : ""), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
        float _p1_5 = _is_spx ? 7030.0 : 26160.0
        if not na(_p1_5)
            array.push(_lines, line.new(_bi1, _p1_5, _bi1 + W, _p1_5, color=C_NEG, style=f_style(STY_N2), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_5, "n2 " + str.tostring(math.round(_p1_5)) + (_is_spx ? "" : ""), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
        float _p1_6 = _is_spx ? 6850.0 : 26070.0
        if not na(_p1_6)
            array.push(_lines, line.new(_bi1, _p1_6, _bi1 + W, _p1_6, color=C_NEG, style=f_style(STY_N3), width=2))
            array.push(_labels, label.new(_bi1 + W, _p1_6, "n3 " + str.tostring(math.round(_p1_6)) + (_is_spx ? "" : ""), color=color.new(color.black, 100), textcolor=C_NEG, style=label.style_none, size=size.small))
