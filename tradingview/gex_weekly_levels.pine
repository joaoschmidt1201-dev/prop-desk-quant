        f_draw_level(_t1, _t2, 700.0, C_P1, STY_P1, LW_P1, (SH_P1 or SH_P2 or SH_P3), "p + coi ($" + str.tostring(math.round(700.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 695.0, C_P1, STY_P1, LW_P1, (SH_P1 or SH_P2 or SH_P3), "p ($" + str.tostring(math.round(695.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 690.0, C_P1, STY_P1, LW_P1, (SH_P1 or SH_P2 or SH_P3), "p3 + ag ($" + str.tostring(math.round(690.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 688.0, C_P1, STY_P1, LW_P1, (SH_P1 or SH_P2 or SH_P3), "p3 ($" + str.tostring(math.round(688.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
        f_draw_level(_t1, _t2, 685.0, C_P1, STY_P1, LW_P1, (SH_P1 or SH_P2 or SH_P3), "p2 + ag ($" + str.tostring(math.round(685.0)) + ")" + (SHOW_TS ? " [" + _update_date + "]" : ""))
