v_w20  = request.security(syminfo.tickerid, tf_w, ta.ema(close, 20), gaps=barmerge.gaps_off)
plot(sh_w20 ? v_w20 : na, "W EMA 20", color=c_w_ema20, linewidth=wd_w20, style=plot.style_stepline, display=display.pane + display.data_window)
