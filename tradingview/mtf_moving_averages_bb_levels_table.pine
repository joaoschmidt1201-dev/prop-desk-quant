grp_w = "WEEKLY Settings (W)"
tf_w  = input.timeframe("W", "Timeframe", group=grp_w, display=display.data_window)

// Transparency for Weekly
c_w_ema9   = color.new(c_ema9, 30)
c_w_ema20  = color.new(c_ema20, 30)
c_w_sma50  = color.new(c_sma50, 30)
c_w_sma200 = color.new(c_sma200, 30)
c_w_bb     = color.new(c_bb, 30)

// --- EMA 9 (W) ---
sh_w9  = input.bool(true, "EMA 9", group=grp_w, inline="w9", display=display.data_window)
wd_w9  = input.int(1, "Width", minval=1, maxval=4, group=grp_w, inline="w9", display=display.data_window)
