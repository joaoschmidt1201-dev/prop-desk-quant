plot(sh_h_bb ? v_h_bb_lw : na, "H BBLW", color=c_h_bb, linewidth=wd_h_bb, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_h_bb and lbl_bb, v_h_bb_up, c_bb, "H")
f_price_lbl(sh_h_bb and lbl_bb, v_h_bb_lw, c_bb, "H")


// ==========================================
// LEVELS TABLE: compact 3-column view with D, W and H values side by side.
// ==========================================
f_tbl_size(opt) =>
    opt == "Tiny" ? size.tiny : opt == "Normal" ? size.normal : size.small

c_tbl_bg     = bg_tbl
c_tbl_title  = bg_tbl
c_tbl_border = color.black
tbl_size     = f_tbl_size(sz_tbl)

var table levels_tbl = table.new(pos_tbl, 3, 7, bgcolor=c_tbl_bg, frame_color=c_tbl_border, frame_width=1, border_color=color.new(color.black, 100), border_width=0)

if barstate.isfirst
    table.merge_cells(levels_tbl, 0, 0, 2, 0)

f_title() =>
    table.cell(levels_tbl, 0, 0, "MTF Levels", text_color=txt_tbl, bgcolor=c_tbl_title, text_size=tbl_size, text_halign=text.align_center)

f_cell(col, row, tf, name, value) =>
    txt = tf + " " + name + "  " + f_fmt(value)
    table.cell(levels_tbl, col, row, txt, text_color=txt_tbl, bgcolor=c_tbl_bg, text_size=tbl_size, text_halign=text.align_left)

if barstate.islast
    if sh_tbl
        f_title()
        f_cell(0, 1, "D", "EMA9",  v_d9)
        f_cell(0, 2, "D", "EMA20", v_d20)
        f_cell(0, 3, "D", "MA50",  v_d50)
        f_cell(0, 4, "D", "MA200", v_d200)
        f_cell(0, 5, "D", "BBUP",  v_d_bb_up)
        f_cell(0, 6, "D", "BBLW",  v_d_bb_lw)
        f_cell(1, 1, "W", "EMA9",  v_w9)
        f_cell(1, 2, "W", "EMA20", v_w20)
        f_cell(1, 3, "W", "MA50",  v_w50)
        f_cell(1, 4, "W", "MA200", v_w200)
        f_cell(1, 5, "W", "BBUP",  v_w_bb_up)
        f_cell(1, 6, "W", "BBLW",  v_w_bb_lw)
        f_cell(2, 1, "H", "EMA9",  v_h9)
        f_cell(2, 2, "H", "EMA20", v_h20)
        f_cell(2, 3, "H", "MA50",  v_h50)
        f_cell(2, 4, "H", "MA200", v_h200)
        f_cell(2, 5, "H", "BBUP",  v_h_bb_up)
        f_cell(2, 6, "H", "BBLW",  v_h_bb_lw)
    else
        table.clear(levels_tbl, 0, 0, 2, 6)
