//@version=6

// 1. STANDARDIZATION: Name [ST]
indicator("MTF MAs & BB [ST]", overlay=true)

// 2. VERSION CONTROL
string ver_num  = "v6.0"
string ver_date = "2026-06-25"
// v6.0 (CZ): migrated //@version=5 -> 6 for publishing. No logic change — code already
//            v6-clean (no na-bools, no int-div, ta.*/request.security at global scope,
//            linewidth>=1, no transp/offset-series). Note: color.red hex shifts slightly in v6.
// v5.16 (CZ): label background is now a toggle (lbl_bg) — ON = colored highlight tag,
//             OFF = text only. Plus text color input for the background-on case.
// v5.14 (CZ): + Hourly (H) timeframe (table column + plots) ; + price labels at the
//             right edge of every plotted line (to read D/W/H MA levels on 15/5/2m charts).
// v5.15 (CZ): price labels with NO background (style_none), text in the line's solid color
//             -> readable on a white chart, no clutter.

// --- DEFAULT COLORS ---
c_ema9   = #2962ff  // Blue
c_ema20  = #ff9800  // Orange
c_sma50  = #4caf50  // Green
c_sma200 = #f23645  // Red
c_bb     = #808080  // Gray (Bollinger Bands)

// --- SHARED FORMATTER (used by labels and table) ---
f_fmt(v) =>
    na(v) ? "n/a" : str.tostring(v, format.mintick)

// ==========================================
// GROUP 0: LEVELS TABLE
// ==========================================
grp_tbl = "LEVELS TABLE"
sh_tbl  = input.bool(true, "Show Levels Table", group=grp_tbl)
pos_tbl = input.string(position.top_right, "Position", options=[position.top_right, position.middle_right, position.bottom_right, position.top_left], group=grp_tbl)
sz_tbl  = input.string("Tiny", "Text Size", options=["Tiny", "Small", "Normal"], group=grp_tbl)
txt_tbl = input.color(color.red, "Text Color", group=grp_tbl)
bg_tbl  = input.color(color.new(color.white, 85), "Background Color", group=grp_tbl)

// ==========================================
// GROUP 0b: PRICE LABELS (on the line, right edge)
// ==========================================
grp_lbl = "PRICE LABELS (on lines)"
sh_lbl  = input.bool(true, "Show price labels on lines", group=grp_lbl, tooltip="Small price tag at the right end of each plotted MA/BB line. Helps locate D/W/H levels on 15/5/2m charts.")
lbl_off = input.int(3, "Label offset (bars to the right)", minval=0, maxval=50, group=grp_lbl)
lbl_sz  = input.string("Tiny", "Label Size", options=["Tiny", "Small", "Normal"], group=grp_lbl)
lbl_bg  = input.bool(true, "Label background (highlight numbers)", group=grp_lbl, tooltip="On = colored tag behind the price (highlight). Off = text only in the line color, no background.")
lbl_txt = input.color(color.white, "Label text color (when background ON)", group=grp_lbl)
lbl_bb  = input.bool(true, "Include Bollinger Bands in labels", group=grp_lbl, tooltip="Off = only the MA lines get a price tag (cleaner). The MAs are the 8 levels CZ tracks.")

f_lbl_size(opt) =>
    opt == "Tiny" ? size.tiny : opt == "Normal" ? size.normal : size.small
lblsz = f_lbl_size(lbl_sz)

// Manage one persistent label per call site (each `var` is independent per call location).
// tag = timeframe letter (D/W/H) so same-colored MAs across TFs stay distinguishable.
f_price_lbl(show, value, col, tag) =>
    var label lb = na
    show_now = sh_lbl and show and not na(value) and barstate.islast
    // ramos de UM bloco só (sem if/else misturando 'label' e 'void' -> erro de tipo no Pine)
    // toggle lbl_bg: ON = tag colorida (fundo=cor da linha, texto=lbl_txt) p/ destacar o numero;
    //               OFF = style_none (so texto na cor da linha) -> nitido em grafico branco, sem poluir
    sty = lbl_bg ? label.style_label_left : label.style_none
    bgc = lbl_bg ? col : color.new(color.white, 100)
    txc = lbl_bg ? lbl_txt : col
    if show_now and na(lb)
        lb := label.new(bar_index + lbl_off, value, tag + " " + f_fmt(value), xloc=xloc.bar_index, style=sty, color=bgc, textcolor=txc, size=lblsz)
    if show_now
        label.set_xy(lb, bar_index + lbl_off, value)
        label.set_text(lb, tag + " " + f_fmt(value))
        label.set_style(lb, sty)
        label.set_color(lb, bgc)
        label.set_textcolor(lb, txc)
        label.set_size(lb, lblsz)
    if not show_now and not na(lb)
        label.delete(lb)
        lb := na

// ==========================================
// GROUP 1: DAILY MAs & BB (D)
// ==========================================
grp_d = "DAILY Settings (D)"
tf_d  = input.timeframe("D", "Timeframe", group=grp_d, display=display.data_window)

// --- EMA 9 ---
sh_d9  = input.bool(true, "EMA 9", group=grp_d, inline="d9", display=display.data_window)
wd_d9  = input.int(1, "Width", minval=1, maxval=4, group=grp_d, inline="d9", display=display.data_window)
v_d9   = request.security(syminfo.tickerid, tf_d, ta.ema(close, 9), gaps=barmerge.gaps_off)
plot(sh_d9 ? v_d9 : na, "D EMA 9", color=c_ema9, linewidth=wd_d9, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_d9, v_d9, c_ema9, "D")

// --- EMA 20 ---
sh_d20 = input.bool(true, "EMA 20", group=grp_d, inline="d20", display=display.data_window)
wd_d20 = input.int(1, "Width", minval=1, maxval=4, group=grp_d, inline="d20", display=display.data_window)
v_d20  = request.security(syminfo.tickerid, tf_d, ta.ema(close, 20), gaps=barmerge.gaps_off)
plot(sh_d20 ? v_d20 : na, "D EMA 20", color=c_ema20, linewidth=wd_d20, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_d20, v_d20, c_ema20, "D")

// --- SMA 50 ---
sh_d50 = input.bool(true, "SMA 50", group=grp_d, inline="d50", display=display.data_window)
wd_d50 = input.int(2, "Width", minval=1, maxval=4, group=grp_d, inline="d50", display=display.data_window)
v_d50  = request.security(syminfo.tickerid, tf_d, ta.sma(close, 50), gaps=barmerge.gaps_off)
plot(sh_d50 ? v_d50 : na, "D SMA 50", color=c_sma50, linewidth=wd_d50, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_d50, v_d50, c_sma50, "D")

// --- SMA 200 ---
sh_d200 = input.bool(false, "SMA 200", group=grp_d, inline="d200", display=display.data_window)
wd_d200 = input.int(2, "Width", minval=1, maxval=4, group=grp_d, inline="d200", display=display.data_window)
v_d200  = request.security(syminfo.tickerid, tf_d, ta.sma(close, 200), gaps=barmerge.gaps_off)
plot(sh_d200 ? v_d200 : na, "D SMA 200", color=c_sma200, linewidth=wd_d200, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_d200, v_d200, c_sma200, "D")

// --- BOLLINGER BANDS (D) ---
sh_d_bb = input.bool(true, "Bollinger Bands 20,2", group=grp_d, inline="dbb", display=display.data_window)
wd_d_bb = input.int(1, "Width", minval=1, maxval=4, group=grp_d, inline="dbb", display=display.data_window)
[_, v_d_bb_up, v_d_bb_lw] = request.security(syminfo.tickerid, tf_d, ta.bb(close, 20, 2.0), gaps=barmerge.gaps_off)
plot(sh_d_bb ? v_d_bb_up : na, "D BBUP", color=c_bb, linewidth=wd_d_bb, style=plot.style_stepline, display=display.pane + display.data_window)
plot(sh_d_bb ? v_d_bb_lw : na, "D BBLW", color=c_bb, linewidth=wd_d_bb, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_d_bb and lbl_bb, v_d_bb_up, c_bb, "D")
f_price_lbl(sh_d_bb and lbl_bb, v_d_bb_lw, c_bb, "D")


// ==========================================
// GROUP 2: WEEKLY MAs & BB (W)
