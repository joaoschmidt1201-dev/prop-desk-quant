// --- SMA 50 (W) ---
sh_w50 = input.bool(true, "SMA 50", group=grp_w, inline="w50", display=display.data_window)
wd_w50 = input.int(2, "Width", minval=1, maxval=4, group=grp_w, inline="w50", display=display.data_window)
v_w50  = request.security(syminfo.tickerid, tf_w, ta.sma(close, 50), gaps=barmerge.gaps_off)
plot(sh_w50 ? v_w50 : na, "W SMA 50", color=c_w_sma50, linewidth=wd_w50, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_w50, v_w50, c_sma50, "W")

// --- SMA 200 (W) ---
sh_w200 = input.bool(false, "SMA 200", group=grp_w, inline="w200", display=display.data_window)
wd_w200 = input.int(2, "Width", minval=1, maxval=4, group=grp_w, inline="w200", display=display.data_window)
v_w200  = request.security(syminfo.tickerid, tf_w, ta.sma(close, 200), gaps=barmerge.gaps_off)
plot(sh_w200 ? v_w200 : na, "W SMA 200", color=c_w_sma200, linewidth=wd_w200, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_w200, v_w200, c_sma200, "W")

// --- BOLLINGER BANDS (W) ---
sh_w_bb = input.bool(true, "Bollinger Bands 20,2", group=grp_w, inline="wbb", display=display.data_window)
wd_w_bb = input.int(1, "Width", minval=1, maxval=4, group=grp_w, inline="wbb", display=display.data_window)
[_, v_w_bb_up, v_w_bb_lw] = request.security(syminfo.tickerid, tf_w, ta.bb(close, 20, 2.0), gaps=barmerge.gaps_off)
plot(sh_w_bb ? v_w_bb_up : na, "W BBUP", color=c_w_bb, linewidth=wd_w_bb, style=plot.style_stepline, display=display.pane + display.data_window)
plot(sh_w_bb ? v_w_bb_lw : na, "W BBLW", color=c_w_bb, linewidth=wd_w_bb, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_w_bb and lbl_bb, v_w_bb_up, c_bb, "W")
f_price_lbl(sh_w_bb and lbl_bb, v_w_bb_lw, c_bb, "W")


// ==========================================
// GROUP 3: HOURLY MAs & BB (H)
// ==========================================
grp_h = "HOURLY Settings (H)"
tf_h  = input.timeframe("60", "Timeframe", group=grp_h, display=display.data_window)

// Transparency for Hourly (more faded than Weekly to separate the three TFs visually)
c_h_ema9   = color.new(c_ema9, 55)
c_h_ema20  = color.new(c_ema20, 55)
c_h_sma50  = color.new(c_sma50, 55)
c_h_sma200 = color.new(c_sma200, 55)
c_h_bb     = color.new(c_bb, 55)

// --- EMA 9 (H) ---
sh_h9  = input.bool(true, "EMA 9", group=grp_h, inline="h9", display=display.data_window)
wd_h9  = input.int(1, "Width", minval=1, maxval=4, group=grp_h, inline="h9", display=display.data_window)
v_h9   = request.security(syminfo.tickerid, tf_h, ta.ema(close, 9), gaps=barmerge.gaps_off)
plot(sh_h9 ? v_h9 : na, "H EMA 9", color=c_h_ema9, linewidth=wd_h9, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_h9, v_h9, c_ema9, "H")

// --- EMA 20 (H) ---
sh_h20 = input.bool(true, "EMA 20", group=grp_h, inline="h20", display=display.data_window)
wd_h20 = input.int(1, "Width", minval=1, maxval=4, group=grp_h, inline="h20", display=display.data_window)
v_h20  = request.security(syminfo.tickerid, tf_h, ta.ema(close, 20), gaps=barmerge.gaps_off)
plot(sh_h20 ? v_h20 : na, "H EMA 20", color=c_h_ema20, linewidth=wd_h20, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_h20, v_h20, c_ema20, "H")

// --- SMA 50 (H) ---
sh_h50 = input.bool(true, "SMA 50", group=grp_h, inline="h50", display=display.data_window)
wd_h50 = input.int(2, "Width", minval=1, maxval=4, group=grp_h, inline="h50", display=display.data_window)
v_h50  = request.security(syminfo.tickerid, tf_h, ta.sma(close, 50), gaps=barmerge.gaps_off)
plot(sh_h50 ? v_h50 : na, "H SMA 50", color=c_h_sma50, linewidth=wd_h50, style=plot.style_stepline, display=display.pane + display.data_window)
f_price_lbl(sh_h50, v_h50, c_sma50, "H")

// --- SMA 200 (H) ---
sh_h200 = input.bool(false, "SMA 200", group=grp_h, inline="h200", display=display.data_window)
wd_h200 = input.int(2, "Width", minval=1, maxval=4, group=grp_h, inline="h200", display=display.data_window)
v_h200  = request.security(syminfo.tickerid, tf_h, ta.sma(close, 200), gaps=barmerge.gaps_off)
plot(sh_h200 ? v_h200 : na, "H SMA 200", color=c_h_sma200, linewidth=wd_h200, style=plot.style_stepline, display=display.pane + display.data_window)
