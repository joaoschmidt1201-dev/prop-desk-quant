    body := body + ",\""+n18+"\":["+ticker_csv(a18_t1,a18_b1,a18_k1,a18_f1,a18_t2,a18_b2,a18_k2,a18_f2,a18_t3,a18_b3,a18_k3,a18_f3,a18_t4,a18_b4,a18_k4,a18_f4,a18_t5,a18_b5,a18_k5,a18_f5)+"]"
