// in-Pine table renders; the JSON snapshot always exports all 5 levels.
displayTolIdx = input.int(2, "Display tolerance level (0..4, baseline=2)", minval=0, maxval=4, group=g_main, tooltip="Which of the 5 tolerance levels to render in the in-chart table. The JSON snapshot exports ALL 5 levels regardless of this setting — the dashboard does the picking on the consumer side.")
winSize       = input.int(2, "Lookahead Candles", minval=2, group=g_main)

useSqueezeFilter = input.bool(false, "Filter Low Volatility (Squeeze)?", group=g_filter)
