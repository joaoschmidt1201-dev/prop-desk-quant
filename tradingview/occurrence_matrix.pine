    body := body + ",\""+n27+"\":["+ticker_csv(a27_t1,a27_b1,a27_k1,a27_f1,a27_t2,a27_b2,a27_k2,a27_f2,a27_t3,a27_b3,a27_k3,a27_f3,a27_t4,a27_b4,a27_k4,a27_f4,a27_t5,a27_b5,a27_k5,a27_f5)+"]"
    body := body + ",\""+n28+"\":["+ticker_csv(a28_t1,a28_b1,a28_k1,a28_f1,a28_t2,a28_b2,a28_k2,a28_f2,a28_t3,a28_b3,a28_k3,a28_f3,a28_t4,a28_b4,a28_k4,a28_f4,a28_t5,a28_b5,a28_k5,a28_f5)+"]"
    body := body + ",\""+n29+"\":["+ticker_csv(a29_t1,a29_b1,a29_k1,a29_f1,a29_t2,a29_b2,a29_k2,a29_f2,a29_t3,a29_b3,a29_k3,a29_f3,a29_t4,a29_b4,a29_k4,a29_f4,a29_t5,a29_b5,a29_k5,a29_f5)+"]"

    string payload = head + body + "}}"
    if must_log
        log.info(payload)
    if must_alert
        alert(payload, alert.freq_once_per_bar_close)
