if must_alert
    // Auto Friday-close alert path: webhook receivers must concatenate the
    // sequence of alert() calls between BEGIN and END markers.
    [eg1_0, eg1_1, eg1_2, eg1_3, eg1_4] = get_tol_grid(0)
    [eg2_0, eg2_1, eg2_2, eg2_3, eg2_4] = get_tol_grid(1)
