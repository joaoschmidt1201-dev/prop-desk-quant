sma_long_p = input.int(200, "SMA long period",  group=g_main)

tablePos        = input.string("middle_right", "Table Position", options=["top_right", "middle_right", "bottom_right", "top_left", "middle_left", "bottom_left"], group=g_table)
tableTextSize   = input.string("tiny",         "Table Text Size", options=["tiny", "small", "normal"], group=g_table)
compactMode     = input.bool(true,  "Compact Mode (hide sample size in cell)", group=g_table, tooltip="Off = '52.3%\\nn=156' (2 lines). On = '52.3%' (1 line, mais denso).")
minSampleHL     = input.int(20, "Min sample to mark 'best' MA", minval=0, group=g_table, tooltip="Cells with fewer occurrences than this are not eligible for the green highlight (best Bounce%). Avoids noisy small-sample winners.")

showIdx     = input.bool(true,  "Show Indices/Futures",   group=g_table)
showCrypto  = input.bool(true,  "Show Crypto",            group=g_table)
showFX      = input.bool(true,  "Show FX",                group=g_table)
