// ==========================================
// 8. DIRECT-CHART PARITY TEST (bypasses request.security)
// ==========================================
// Runs the SAME state machine directly on the chart's symbol using (dbgMA, dbgTolIdx)
// to isolate whether discrepancy vs OS [ST] comes from the request.security wrapper.
if dbgEnable
    int dbg_ma_idx = dbgMA == "EMA9" ? 0 : dbgMA == "EMA20" ? 1 : dbgMA == "SMA50" ? 2 : dbgMA == "SMA200" ? 3 : 4
    [_dg0, _dg1, _dg2, _dg3, _dg4] = get_tol_grid(dbg_ma_idx)
    float dbg_tol = dbgTolIdx == 0 ? _dg0 : dbgTolIdx == 1 ? _dg1 : dbgTolIdx == 2 ? _dg2 : dbgTolIdx == 3 ? _dg3 : _dg4

    float dbg_ma = dbgMA == "EMA9"   ? ta.ema(close, ema_fast_p) :
                   dbgMA == "EMA20"  ? ta.ema(close, ema_slow_p) :
                   dbgMA == "SMA50"  ? ta.sma(close, sma_mid_p)  :
                   dbgMA == "SMA200" ? ta.sma(close, sma_long_p) :
                                       ta.vwap

    [_dm, _dub, _dlb] = ta.bb(close, 20, 2.0)
    _dbk  = ta.sma(close, 20)
    _drk  = ta.tr(true)
    _dark = ta.sma(_drk, 20)
    _dukc = _dbk + _dark * 1.5
    _dlkc = _dbk - _dark * 1.5
    bool dbg_sqz = (_dub < _dukc) and (_dlb > _dlkc)

    [d_t, d_b, d_k, d_f] = run_sm(dbg_ma, dbg_sqz, dbg_tol > 0 ? dbg_tol : 0.0001, true, "DIRECT-" + dbgMA + "[" + str.tostring(dbgTolIdx) + "]")

    if barstate.islast
        log.info("=== DIRECT-CHART | " + syminfo.ticker + " " + timeframe.period + " " + dbgMA + " tol_idx=" + str.tostring(dbgTolIdx) + " tol=" + str.tostring(dbg_tol) + "% | Total=" + str.tostring(d_t) + " Bounce=" + str.tostring(d_b) + " Break=" + str.tostring(d_k) + " False=" + str.tostring(d_f) + " ===")
