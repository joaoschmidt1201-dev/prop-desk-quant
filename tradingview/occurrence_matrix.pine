// ==========================================
// 5. TABLE RENDERING
// ==========================================
position_of(string s) =>
    s == "top_right"     ? position.top_right     :
      s == "middle_right"  ? position.middle_right  :
      s == "bottom_right"  ? position.bottom_right  :
      s == "top_left"      ? position.top_left      :
      s == "middle_left"   ? position.middle_left   :
      s == "bottom_left"   ? position.bottom_left   :
                             position.middle_right

text_size_of(string s) =>
    s == "tiny" ? size.tiny : s == "small" ? size.small : size.normal

// 30 rows = 1 header + 29 tickers; 6 cols = ticker name + 5 MAs
var table tbl = table.new(position_of(tablePos), 6, 30, bgcolor=color.new(color.black, 70), border_width=1, border_color=color.new(color.gray, 60))

// Renderiza uma célula (Bounce% + n=Total). Highlight verde se for o "best" da linha.
fmt_cell(int col_idx, int row_idx, int t, float r, int best_col, string sz) =>
    if t == 0
        table.cell(tbl, col_idx, row_idx, "—", text_color=color.new(color.gray, 30), bgcolor=color.new(color.black, 90), text_size=sz)
    else
        string txt = str.tostring(math.round(r, 1)) + "%\nn=" + str.tostring(t)
        bool is_best = col_idx == best_col
        color bg = is_best ? color.new(color.green, 60) : color.new(color.black, 90)
        color fg = is_best ? color.new(color.lime, 0)   : color.new(color.white, 0)
        table.cell(tbl, col_idx, row_idx, txt, text_color=fg, bgcolor=bg, text_size=sz)

// Renderiza uma linha completa, calcula o "best Bounce%" considerando minSampleHL
render_row(int row, string name, int t1, int b1, int t2, int b2, int t3, int b3, int t4, int b4, int t5, int b5, string sz) =>
    table.cell(tbl, 0, row, name, text_color=color.new(color.white, 0), bgcolor=color.new(color.black, 50), text_size=sz)

    float r1 = t1 > 0 ? b1 * 100.0 / t1 : -1.0
    float r2 = t2 > 0 ? b2 * 100.0 / t2 : -1.0
    float r3 = t3 > 0 ? b3 * 100.0 / t3 : -1.0
    float r4 = t4 > 0 ? b4 * 100.0 / t4 : -1.0
    float r5 = t5 > 0 ? b5 * 100.0 / t5 : -1.0

    int   best_col = 0
    float best_val = -1.0
    if t1 >= minSampleHL and r1 > best_val
        best_val := r1
        best_col := 1
    if t2 >= minSampleHL and r2 > best_val
        best_val := r2
        best_col := 2
    if t3 >= minSampleHL and r3 > best_val
        best_val := r3
        best_col := 3
    if t4 >= minSampleHL and r4 > best_val
        best_val := r4
        best_col := 4
    if t5 >= minSampleHL and r5 > best_val
        best_val := r5
        best_col := 5

    fmt_cell(1, row, t1, r1, best_col, sz)
    fmt_cell(2, row, t2, r2, best_col, sz)
    fmt_cell(3, row, t3, r3, best_col, sz)
    fmt_cell(4, row, t4, r4, best_col, sz)
    fmt_cell(5, row, t5, r5, best_col, sz)

if barstate.islast
    string sz = tableTextSize

    // Header
    string tf_label = "[" + timeframe.period + "]"
    table.cell(tbl, 0, 0, "Ticker " + tf_label, text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)
    table.cell(tbl, 1, 0, "EMA " + str.tostring(ema_fast_p), text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)
    table.cell(tbl, 2, 0, "EMA " + str.tostring(ema_slow_p), text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)
    table.cell(tbl, 3, 0, "SMA " + str.tostring(sma_mid_p),  text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)
    table.cell(tbl, 4, 0, "SMA " + str.tostring(sma_long_p), text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)
    table.cell(tbl, 5, 0, "VWAP",                            text_color=color.new(color.white, 0), bgcolor=color.new(color.gray, 30), text_size=sz)

    // 29 ticker rows
    render_row( 1, n01, a01_t1,a01_b1, a01_t2,a01_b2, a01_t3,a01_b3, a01_t4,a01_b4, a01_t5,a01_b5, sz)
    render_row( 2, n02, a02_t1,a02_b1, a02_t2,a02_b2, a02_t3,a02_b3, a02_t4,a02_b4, a02_t5,a02_b5, sz)
    render_row( 3, n03, a03_t1,a03_b1, a03_t2,a03_b2, a03_t3,a03_b3, a03_t4,a03_b4, a03_t5,a03_b5, sz)
    render_row( 4, n04, a04_t1,a04_b1, a04_t2,a04_b2, a04_t3,a04_b3, a04_t4,a04_b4, a04_t5,a04_b5, sz)
    render_row( 5, n05, a05_t1,a05_b1, a05_t2,a05_b2, a05_t3,a05_b3, a05_t4,a05_b4, a05_t5,a05_b5, sz)
    render_row( 6, n06, a06_t1,a06_b1, a06_t2,a06_b2, a06_t3,a06_b3, a06_t4,a06_b4, a06_t5,a06_b5, sz)
    render_row( 7, n07, a07_t1,a07_b1, a07_t2,a07_b2, a07_t3,a07_b3, a07_t4,a07_b4, a07_t5,a07_b5, sz)
    render_row( 8, n08, a08_t1,a08_b1, a08_t2,a08_b2, a08_t3,a08_b3, a08_t4,a08_b4, a08_t5,a08_b5, sz)
    render_row( 9, n09, a09_t1,a09_b1, a09_t2,a09_b2, a09_t3,a09_b3, a09_t4,a09_b4, a09_t5,a09_b5, sz)
    render_row(10, n10, a10_t1,a10_b1, a10_t2,a10_b2, a10_t3,a10_b3, a10_t4,a10_b4, a10_t5,a10_b5, sz)
    render_row(11, n11, a11_t1,a11_b1, a11_t2,a11_b2, a11_t3,a11_b3, a11_t4,a11_b4, a11_t5,a11_b5, sz)
    render_row(12, n12, a12_t1,a12_b1, a12_t2,a12_b2, a12_t3,a12_b3, a12_t4,a12_b4, a12_t5,a12_b5, sz)
    render_row(13, n13, a13_t1,a13_b1, a13_t2,a13_b2, a13_t3,a13_b3, a13_t4,a13_b4, a13_t5,a13_b5, sz)
    render_row(14, n14, a14_t1,a14_b1, a14_t2,a14_b2, a14_t3,a14_b3, a14_t4,a14_b4, a14_t5,a14_b5, sz)
    render_row(15, n15, a15_t1,a15_b1, a15_t2,a15_b2, a15_t3,a15_b3, a15_t4,a15_b4, a15_t5,a15_b5, sz)
    render_row(16, n16, a16_t1,a16_b1, a16_t2,a16_b2, a16_t3,a16_b3, a16_t4,a16_b4, a16_t5,a16_b5, sz)
    render_row(17, n17, a17_t1,a17_b1, a17_t2,a17_b2, a17_t3,a17_b3, a17_t4,a17_b4, a17_t5,a17_b5, sz)
    render_row(18, n18, a18_t1,a18_b1, a18_t2,a18_b2, a18_t3,a18_b3, a18_t4,a18_b4, a18_t5,a18_b5, sz)
    render_row(19, n19, a19_t1,a19_b1, a19_t2,a19_b2, a19_t3,a19_b3, a19_t4,a19_b4, a19_t5,a19_b5, sz)
    render_row(20, n20, a20_t1,a20_b1, a20_t2,a20_b2, a20_t3,a20_b3, a20_t4,a20_b4, a20_t5,a20_b5, sz)
    render_row(21, n21, a21_t1,a21_b1, a21_t2,a21_b2, a21_t3,a21_b3, a21_t4,a21_b4, a21_t5,a21_b5, sz)
    render_row(22, n22, a22_t1,a22_b1, a22_t2,a22_b2, a22_t3,a22_b3, a22_t4,a22_b4, a22_t5,a22_b5, sz)
    render_row(23, n23, a23_t1,a23_b1, a23_t2,a23_b2, a23_t3,a23_b3, a23_t4,a23_b4, a23_t5,a23_b5, sz)
    render_row(24, n24, a24_t1,a24_b1, a24_t2,a24_b2, a24_t3,a24_b3, a24_t4,a24_b4, a24_t5,a24_b5, sz)
    render_row(25, n25, a25_t1,a25_b1, a25_t2,a25_b2, a25_t3,a25_b3, a25_t4,a25_b4, a25_t5,a25_b5, sz)
    render_row(26, n26, a26_t1,a26_b1, a26_t2,a26_b2, a26_t3,a26_b3, a26_t4,a26_b4, a26_t5,a26_b5, sz)
    render_row(27, n27, a27_t1,a27_b1, a27_t2,a27_b2, a27_t3,a27_b3, a27_t4,a27_b4, a27_t5,a27_b5, sz)
    render_row(28, n28, a28_t1,a28_b1, a28_t2,a28_b2, a28_t3,a28_b3, a28_t4,a28_b4, a28_t5,a28_b5, sz)
    render_row(29, n29, a29_t1,a29_b1, a29_t2,a29_b2, a29_t3,a29_b3, a29_t4,a29_b4, a29_t5,a29_b5, sz)

// ==========================================
// 6. FRIDAY CLOSE SNAPSHOT ALERT
// ==========================================
// Empacota Total/Bounce/Break/False de 1 ticker (5 MAs = 20 ints) em CSV
ticker_csv(int t1, int b1, int k1, int f1, int t2, int b2, int k2, int f2, int t3, int b3, int k3, int f3, int t4, int b4, int k4, int f4, int t5, int b5, int k5, int f5) =>
    str.tostring(t1) + "," + str.tostring(b1) + "," + str.tostring(k1) + "," + str.tostring(f1) + "," + str.tostring(t2) + "," + str.tostring(b2) + "," + str.tostring(k2) + "," + str.tostring(f2) + "," + str.tostring(t3) + "," + str.tostring(b3) + "," + str.tostring(k3) + "," + str.tostring(f3) + "," + str.tostring(t4) + "," + str.tostring(b4) + "," + str.tostring(k4) + "," + str.tostring(f4) + "," + str.tostring(t5) + "," + str.tostring(b5) + "," + str.tostring(k5) + "," + str.tostring(f5)

// Trigger conditions
// - must_log: imprime no Pine Logs assim que o chart carrega (modo manual, copy/paste)
// - must_alert: dispara webhook na Sexta D1 close (modo automatizado, requer alert configurado)
is_friday_close = dayofweek == dayofweek.friday and timeframe.period == "D"
must_log        = printSnapshot and barstate.islast
must_alert      = enableAlert  and is_friday_close

if must_log or must_alert
    string head = "{\"d\":\"" + str.format_time(time, "yyyy-MM-dd", syminfo.timezone) + "\",\"tf\":\"" + timeframe.period + "\",\"ma\":[" + str.tostring(ema_fast_p) + "," + str.tostring(ema_slow_p) + "," + str.tostring(sma_mid_p) + "," + str.tostring(sma_long_p) + ",\"vwap\"],\"data\":{"
    string body = ""
    body := body + "\""+n01+"\":["+ticker_csv(a01_t1,a01_b1,a01_k1,a01_f1,a01_t2,a01_b2,a01_k2,a01_f2,a01_t3,a01_b3,a01_k3,a01_f3,a01_t4,a01_b4,a01_k4,a01_f4,a01_t5,a01_b5,a01_k5,a01_f5)+"]"
    body := body + ",\""+n02+"\":["+ticker_csv(a02_t1,a02_b1,a02_k1,a02_f1,a02_t2,a02_b2,a02_k2,a02_f2,a02_t3,a02_b3,a02_k3,a02_f3,a02_t4,a02_b4,a02_k4,a02_f4,a02_t5,a02_b5,a02_k5,a02_f5)+"]"
    body := body + ",\""+n03+"\":["+ticker_csv(a03_t1,a03_b1,a03_k1,a03_f1,a03_t2,a03_b2,a03_k2,a03_f2,a03_t3,a03_b3,a03_k3,a03_f3,a03_t4,a03_b4,a03_k4,a03_f4,a03_t5,a03_b5,a03_k5,a03_f5)+"]"
    body := body + ",\""+n04+"\":["+ticker_csv(a04_t1,a04_b1,a04_k1,a04_f1,a04_t2,a04_b2,a04_k2,a04_f2,a04_t3,a04_b3,a04_k3,a04_f3,a04_t4,a04_b4,a04_k4,a04_f4,a04_t5,a04_b5,a04_k5,a04_f5)+"]"
    body := body + ",\""+n05+"\":["+ticker_csv(a05_t1,a05_b1,a05_k1,a05_f1,a05_t2,a05_b2,a05_k2,a05_f2,a05_t3,a05_b3,a05_k3,a05_f3,a05_t4,a05_b4,a05_k4,a05_f4,a05_t5,a05_b5,a05_k5,a05_f5)+"]"
