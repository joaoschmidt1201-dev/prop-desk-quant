// ==========================================
// 2. STATE MACHINE — paridade exata com Occurrence Scanner v10.3
// ==========================================
// Recebe a MA já calculada e o estado do squeeze do contexto atual,
// roda a state machine bar-a-bar e retorna [Total, Bounce, Break, False].

run_sm(float ma_val, bool sqz_on) =>
    var int  cT       = 0
    var int  cB       = 0
    var int  cBk      = 0
    var int  cF       = 0
    var bool in_event = false
    var int  timer    = 0
    var bool ts       = false
    var int  tr_idx   = 0
    var int  cv       = 0
    var bool vio      = false
    var bool ew       = false

    upper_buf = ma_val * (1 + approx / 100)
    lower_buf = ma_val * (1 - approx / 100)

    bool touched = (low <= upper_buf and high >= lower_buf)
    bool crossed = ta.crossover(close, ma_val) or ta.crossunder(close, ma_val)
    bool ok_date = not useDateFilter or time >= startDate
    bool ok_vol  = not useSqueezeFilter or not sqz_on

    if (touched or crossed) and not in_event and ok_date and ok_vol
        in_event := true
        timer    := 0
        ts       := close[1] > ma_val[1]
        tr_idx   := bar_index
        vio      := false
        ew       := false
        bool out_strict = ts ? close < lower_buf : close > upper_buf
        cv := out_strict ? 1 : 0
        if cv == 1
            vio := true

    if in_event
        if useSqueezeFilter and sqz_on
            in_event := false
            cv := 0
            ew := false
        else
            if bar_index > tr_idx
                timer += 1

            bool ps = ts ? close < lower_buf : close > upper_buf
            bool pr = ts ? close < ma_val    : close > ma_val

            if bar_index > tr_idx
                if cv == 0
                    if ps
                        cv  := cv + 1
                        vio := true
                else
                    if pr
                        cv := cv + 1
                    else
                        cv := 0

            if cv >= 2
                cBk := cBk + 1
                cT  := cT  + 1
                in_event := false
                cv := 0
                ew := false
            else if timer >= winSize
                if cv == 1 and not ew
                    ew := true
                else
                    if not vio
                        cB := cB + 1
                        cT := cT + 1
                    else
                        cF := cF + 1
                        cT := cT + 1
                    in_event := false
                    cv := 0
                    ew := false

    [cT, cB, cBk, cF]

// ==========================================
// 3. WRAPPER — calcula squeeze + 5 MAs no contexto do símbolo solicitado
// ==========================================
run_full() =>
    // Squeeze (mesmos params do v10.3: BB 20/2.0, KC 20/1.5)
    [_, ub, lb] = ta.bb(close, 20, 2.0)
    bk  = ta.sma(close, 20)
    rk  = ta.tr(true)
    ark = ta.sma(rk, 20)
    ukc = bk + ark * 1.5
    lkc = bk - ark * 1.5
    bool sqz = (ub < ukc) and (lb > lkc)

    ma1 = ta.ema(close, ema_fast_p)
    ma2 = ta.ema(close, ema_slow_p)
    ma3 = ta.sma(close, sma_mid_p)
    ma4 = ta.sma(close, sma_long_p)
    ma5 = ta.vwap

    [t1, b1, k1, f1] = run_sm(ma1, sqz)
    [t2, b2, k2, f2] = run_sm(ma2, sqz)
    [t3, b3, k3, f3] = run_sm(ma3, sqz)
    [t4, b4, k4, f4] = run_sm(ma4, sqz)
    [t5, b5, k5, f5] = run_sm(ma5, sqz)

    [t1,b1,k1,f1, t2,b2,k2,f2, t3,b3,k3,f3, t4,b4,k4,f4, t5,b5,k5,f5]

// ==========================================
