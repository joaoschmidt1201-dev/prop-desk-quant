showQQQ     = input.bool(false, "Show QQQ Top 10",        group=g_table, tooltip="Default off — these are read-only references (zero idiosyncratic risk policy).")

g_alert       = "Snapshot Export"
printSnapshot = input.bool(true,  "Print snapshot to Pine Logs (manual mode)", group=g_alert, tooltip="Quando ligado: imprime o payload JSON no painel Pine Logs assim que o chart termina de carregar. Use pra copiar manualmente sem precisar configurar webhook. Abra View → Pine Logs no Pine Editor.")
