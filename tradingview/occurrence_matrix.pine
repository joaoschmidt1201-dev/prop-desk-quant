dbgTicker  = input.string("SPY", "Ticker to log", options=["ES","SPX","SPY","XSP","NQ","NDX","QQQ","RTY","RUT","IWM","BTC","ETH","EURUSD","EURCHF","GBPUSD","GLD","SLV","USO","EWZ","NVDA","AAPL","MSFT","AMZN","GOOGL","AVGO","GOOG","META","TSLA","BRK.B"], group=g_debug)
