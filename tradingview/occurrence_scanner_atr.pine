// This Pine Script® code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// Occurrence Scanner ATR [ST] — ATR-based tolerance band (band = k * ATR) with the BAND-ZONE
// classification (CZ spec): the band is a "fat MA". BOUNCE = price REACHES the band and rejects;
// FALSE/BREAK = price PASSES THROUGH the band (beyond the far edge). v2 counts a bounce per
// REJECTION (re-armed), fixing the two under-counting bugs on tight MAs (merge of clustered
// rejections; a false poisoning later bounces). Built on "Occurrence Scanner [ST]" v10.3 © BigGuavaTrading.
//@version=5
indicator("Occurrence Scanner ATR [ST]", shorttitle="OS ATR [ST]", overlay=true, max_labels_count=500)

string ver_num  = "v3.1-BAND"
string ver_date = "2026-07-08"

// ==========================================
// 1. INPUTS
// ==========================================
grp_main = "Main Configuration"
grp_band = "Tolerance Band"
grp_date = "Backtest Period"
grp_sqz  = "Squeeze Filter (Anti-Chop)"

maType   = input.string("EMA", "MA Type", options=["SMA", "EMA", "VWAP"], group=grp_main)
maLength = input.int(20, "MA Period", minval=1, group=grp_main)

bandMode = input.string("ATR", "Band Mode", options=["ATR", "Sigma", "Percent"], group=grp_band, tooltip="ATR = k*ATR(N): SAME width for every MA -> fair comparison across MAs, auto-scales across tickers (RECOMMENDED, calibrated). Sigma = k*stdev(close-MA,N): comparable across tickers but inflates slow MAs. Percent = MA*(k/100): legacy fixed %.")
k        = input.float(0.2, "k  (band = k * ATR)", step=0.05, group=grp_band, tooltip="Band half-width in ATR units. Calibrated value = 0.2. A touch = price came within k ATRs of the MA (reaching the band = a bounce).")
bandN    = input.int(100, "Band Window (ATR / Sigma length)", minval=2, group=grp_band)

useSqueezeFilter = input.bool(false, "Filter Low Volatility (Squeeze)?", group=grp_sqz)
useDateFilter    = input.bool(true, "Filter Start Date?", group=grp_date)
startDate        = input.time(timestamp("01 Jan 2018 00:00 +0000"), "Start Date", group=grp_date)

// ==========================================
// 2. CALCULATIONS
// ==========================================
float ma = maType == "SMA" ? ta.sma(close, maLength) : maType == "EMA" ? ta.ema(close, maLength) : ta.vwap

// Absolute band (k * ATR by default). ATR is MA-independent -> the band is the SAME width for
// every MA, so Bounce% is comparable across MAs (a slow MA no longer gets an inflated band).
float atrBand = ta.atr(bandN)
float sigBand = ta.stdev(close - ma, bandN)
float band = bandMode == "ATR" ? k * atrBand : bandMode == "Sigma" ? k * sigBand : ma * (k / 100.0)

upper_buffer = ma + band
lower_buffer = ma - band

// Plot the MA and the tolerance band so the zone is visible.
plot(ma, "Moving Average", color=color.orange, linewidth=2)
pU = plot(upper_buffer, "Band Upper", color=color.new(color.teal, 55))
pL = plot(lower_buffer, "Band Lower", color=color.new(color.teal, 55))
fill(pU, pL, color=color.new(color.teal, 90), title="Tolerance Band")

// ATR for label offset (visual spacing only, fixed 0.5)
atrVal = ta.atr(14)
float labelOffset = 0.5

// Squeeze Logic
lengthSqz = 20
bbMult    = 2.0
kcMult    = 1.5
[middle, upperBB, lowerBB] = ta.bb(close, lengthSqz, bbMult)
basisKC = ta.sma(close, lengthSqz)
rangeKC = ta.tr(true)
avgRangeKC = ta.sma(rangeKC, lengthSqz)
upperKC = basisKC + (avgRangeKC * kcMult)
lowerKC = basisKC - (avgRangeKC * kcMult)
bool is_squeeze_on = (upperBB < upperKC) and (lowerBB > lowerKC)
bgcolor(useSqueezeFilter and is_squeeze_on ? color.new(color.gray, 90) : na, title="Squeeze Active Zone")

// ==========================================
// 3. STATE MACHINE — BAND-ZONE v2 (CZ concept + João rejection/re-arm, 2026-07-08)
// ==========================================
// The band is a "FAT MA"; the band EDGES are the thresholds. BREAK = 2 consecutive closes beyond the
// FAR edge (side flips, chains). FALSE = 1 close beyond the far edge that returns. BOUNCE = an APPROACH
// (opened on a FRESH touch) rejects the band without crossing the far edge — fired when the close returns
// to the ORIGIN region, OR returns to the origin side of the LINE after having crossed it (dip & recover).
// One bounce per approach; re-armed on return to origin (so a false no longer poisons later bounces, and
// clustered rejections on a tight MA are each counted). Validated in scripts/test_occurrence_band.py.
var int  count_Total  = 0
var int  count_Bounce = 0
var int  count_Break  = 0
var int  count_False  = 0

var int  side             = 0      // 0 = not established, +1 above the band, -1 below the band
var int  opp_run          = 0      // consecutive closes beyond the FAR edge
var int  opp_idx          = 0      // bar of the single far-edge close (false marker)
var bool in_appr          = false  // inside a bounce-eligible approach
var int  appr_idx         = 0      // bar the approach opened (bounce marker)
var bool appr_crossed_far = false  // did a close cross the far edge during this approach? (kills bounce)
var bool appr_below_line  = false  // did a close go to the far side of the LINE during this approach?
var bool need_origin      = false  // fired via rejection -> must return to origin before re-arming
var bool prev_touched     = false

// ==========================================
// 4. SCAN GATE (date + squeeze window)
// ==========================================
bool ma_ok      = not na(ma) and not na(band)
bool is_date_ok = not useDateFilter or time >= startDate
bool is_vol_ok  = not useSqueezeFilter or not is_squeeze_on
bool active     = ma_ok and is_date_ok and is_vol_ok

bool touched = low <= upper_buffer and high >= lower_buffer

// ==========================================
// 5. DETECTOR + MARKERS
// ==========================================
// At most ONE event per bar; a single label is drawn, anchored to the extreme of the side under test
// (support -> up-triangle at the low; resistance -> down-triangle at the high). Colour = outcome:
// green bounce / red break / orange false.
bool  ev_now  = false
color ev_col  = na
bool  ev_supp = true
int   ev_idx  = bar_index

if active
    if side == 0
        // Establish the side from the first close OUTSIDE the band.
        if close > upper_buffer
            side := 1
        else if close < lower_buffer
            side := -1
    else
        bool far       = side > 0 ? close < lower_buffer : close > upper_buffer   // beyond the far edge
        bool far_line  = side > 0 ? close < ma           : close > ma             // far side of the LINE
        bool at_origin = side > 0 ? close > upper_buffer : close < lower_buffer    // back in the origin region

        // ---- FAR-EDGE detector: BREAK / FALSE ----
        bool broke = false
        if far
            if opp_run == 0
                opp_idx := bar_index
            opp_run += 1
            if opp_run >= 2                      // BREAK
                count_Break += 1
                count_Total += 1
                ev_now  := true
                ev_col  := color.red
                ev_supp := side > 0             // side BEFORE the flip
                ev_idx  := bar_index
                broke   := true
                side    := -side
                opp_run := 0
        else
            if opp_run == 1                      // poked beyond the far edge once and returned -> FALSE
                count_False += 1
                count_Total += 1
                ev_now  := true
                ev_col  := color.orange
                ev_supp := side > 0
                ev_idx  := opp_idx
            opp_run := 0

        if broke
            in_appr          := false
            appr_crossed_far := false
            appr_below_line  := false
            need_origin      := true
        else
            // ---- returned to origin: close the approach (bounce if eligible) and re-arm ----
            if at_origin
                need_origin := false
                if in_appr and not appr_crossed_far
                    count_Bounce += 1
                    count_Total  += 1
                    ev_now  := true
                    ev_col  := color.green
                    ev_supp := side > 0
                    ev_idx  := appr_idx
                in_appr          := false
                appr_crossed_far := false
                appr_below_line  := false

            // ---- open a fresh approach / update flags ----
            bool fresh = touched and not prev_touched
            if touched and not need_origin
                if fresh and not in_appr
                    in_appr          := true
                    appr_idx         := bar_index
                    appr_crossed_far := far
                    appr_below_line  := far_line
                else if in_appr
                    if far
                        appr_crossed_far := true
                    if far_line
                        appr_below_line := true

            // ---- rejection: back to the origin side of the line after crossing it (dip & recover) ----
            if in_appr and not appr_crossed_far and appr_below_line and not far_line and not at_origin
                count_Bounce += 1
                count_Total  += 1
                ev_now  := true
                ev_col  := color.green
                ev_supp := side > 0
                ev_idx  := appr_idx
                in_appr         := false
                appr_below_line := false
                need_origin     := true

    prev_touched := touched

// Draw the marker (single call site, dynamic history offset — same proven pattern as the original).
if ev_now
    int   back = bar_index - ev_idx
    float off  = atrVal[back] * labelOffset
    float yy   = ev_supp ? low[back] - off : high[back] + off
    string sty = ev_supp ? label.style_triangleup : label.style_triangledown
    label.new(ev_idx, yy, text="", color=ev_col, style=sty, size=size.tiny)

// ==========================================
// 6. STATUS LINE INFO (next to indicator name)
// ==========================================
plot(maLength, title="Period",     display=display.status_line, color=color.new(color.white, 100))
plot(k,        title="k",           display=display.status_line, color=color.new(color.white, 100))
plot(band,     title="Band (abs)",  display=display.status_line, color=color.new(color.white, 100))

// ==========================================
// 7. BOTTOM-RIGHT LEGEND (PRO HUD) — same as the original scanner
// ==========================================
var table hud = table.new(position.bottom_right, 1, 7, bgcolor=color.new(color.gray, 90), border_width=0)

if barstate.islast
    float rate_bounce = count_Total > 0 ? math.round(count_Bounce * 100.0 / count_Total, 1) : 0
    float rate_break  = count_Total > 0 ? math.round(count_Break  * 100.0 / count_Total, 1) : 0
    float rate_false  = count_Total > 0 ? math.round(100.0 - rate_bounce - rate_break, 1) : 0

    string txt_bounce = str.tostring(count_Bounce) + " (" + str.tostring(rate_bounce) + "%)"
    string txt_break  = str.tostring(count_Break)  + " (" + str.tostring(rate_break)  + "%)"
    string txt_false  = str.tostring(count_False)  + " (" + str.tostring(rate_false)  + "%)"

    table.cell(hud, 0, 0, "Occurrence Stats (" + bandMode + " k=" + str.tostring(k, "#.##") + ")", text_color=color.black, text_size=size.small)
    table.cell(hud, 0, 1, "Total: " + str.tostring(count_Total), text_color=color.black, text_size=size.small)
    table.cell(hud, 0, 2, "▲ Bounce: " + txt_bounce, text_color=color.green, text_size=size.normal)
    table.cell(hud, 0, 3, "▼ Break: " + txt_break, text_color=color.red, text_size=size.normal)
    table.cell(hud, 0, 4, "▲/▼ False: " + txt_false, text_color=color.orange, text_size=size.normal)
    table.cell(hud, 0, 5, maType + " " + str.tostring(maLength), text_color=color.black, text_size=size.small)
    table.cell(hud, 0, 6, ver_num + " • " + ver_date, text_color=color.gray, text_size=size.small)
