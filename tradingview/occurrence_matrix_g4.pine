displayTolIdx = input.int(2, "Display tolerance level (0..4, baseline=2)", minval=0, maxval=4, group=g_main, tooltip="Which of the 5 tolerance levels to render in the in-chart table. The JSON snapshot exports the active slice (see Memory Saver). Dashboard picks the level from the merged snapshot.")
