// ==========================================
// 2. TOLERANCE GRID — 5 levels per (TF, MA), index 2 = baseline (v12.8 values)
// ==========================================
// Returns [v0, v1, v2, v3, v4] for the given MA index on the chart's timeframe.
// Index 2 reproduces v12.8's get_tol() exactly. Other indices are "tighter"
// (0, 1) and "looser" (3, 4) variants the dashboard can flip between.
// Index conventions: 0=EMA9, 1=EMA20, 2=SMA50, 3=SMA200, 4=VWAP.
// VWAP D/W is intentionally skipped (returns all zeros → run_full masks output to 0).
get_tol_grid(int ma_idx) =>
    string p = timeframe.period
    float v0 = 0.0
    float v1 = 0.0
    float v2 = 0.0
    float v3 = 0.0
    float v4 = 0.0
    if p == "2" or p == "5"
        v0 := 0.01
        v1 := 0.015
        v2 := 0.02
        v3 := 0.05
        v4 := 0.10
    else if p == "15"
        v0 := 0.02
        v1 := 0.03
        v2 := 0.05
        v3 := 0.10
        v4 := 0.15
    else if p == "60"
        v0 := 0.05
        v1 := 0.07
        v2 := 0.10
        v3 := 0.20
        v4 := 0.30
    else if p == "D"
        if ma_idx == 0 or ma_idx == 1
            v0 := 0.10
            v1 := 0.15
            v2 := 0.20
            v3 := 0.30
            v4 := 0.50
        else if ma_idx == 2 or ma_idx == 3
            v0 := 0.15
            v1 := 0.20
            v2 := 0.30
            v3 := 0.50
            v4 := 0.70
        else if ma_idx == 5 or ma_idx == 6
            v0 := 0.15
            v1 := 0.20
            v2 := 0.30
            v3 := 0.50
            v4 := 0.70
    else if p == "W"
        if ma_idx == 0
            v0 := 0.10
            v1 := 0.15
            v2 := 0.20
            v3 := 0.30
            v4 := 0.50
        else if ma_idx == 1
            v0 := 0.15
            v1 := 0.20
            v2 := 0.30
            v3 := 0.50
            v4 := 0.70
        else if ma_idx == 2 or ma_idx == 3
            v0 := 0.20
            v1 := 0.30
            v2 := 0.40
            v3 := 0.60
            v4 := 0.80
        else if ma_idx == 5 or ma_idx == 6
            v0 := 0.20
            v1 := 0.30
            v2 := 0.40
            v3 := 0.60
            v4 := 0.80
    else
        v0 := 0.05
        v1 := 0.07
        v2 := 0.10
        v3 := 0.20
        v4 := 0.30
    [v0, v1, v2, v3, v4]

// Convenience: returns just the baseline (idx 2) for label / parity helpers.
get_tol_baseline(int ma_idx) =>
    [_a, _b, base, _c, _d] = get_tol_grid(ma_idx)
    base

// ==========================================
// 3. STATE MACHINE — paridade exata com Occurrence Scanner v10.3
// ==========================================
// BAND-ZONE v2 (desk spec, validated in scripts/test_occurrence_band.py, 26/26). The band is a "fat MA"
// (band_abs = k*ATR, absolute). BREAK = 2 consecutive closes beyond the FAR edge (side flips, chains);
// FALSE = 1 close beyond the far edge that returns; BOUNCE = an APPROACH (opened on a fresh touch) that
// rejects the band without crossing the far edge — fired on return to the origin region, or back to the
// origin side of the LINE after crossing it (dip & recover). One per approach; re-armed on return to origin
// (a false no longer poisons later bounces). No lookahead/winSize. `band_abs` = absolute band (was % before).
run_sm(float ma_val, bool sqz_on, float band_abs, bool dbg, string lbl) =>
    var int  cT   = 0
    var int  cB   = 0
    var int  cBk  = 0
    var int  cF   = 0
    var int  side             = 0
    var int  opp_run          = 0
    var int  opp_idx          = 0
    var bool in_appr          = false
    var int  appr_idx         = 0
    var bool appr_crossed_far = false
    var bool appr_below_line  = false
    var bool need_origin      = false
    var bool prev_touched     = false

    float upper = ma_val + band_abs
    float lower = ma_val - band_abs
    bool touched = (low <= upper and high >= lower)
    bool ok_date = not useDateFilter or time >= startDate
    bool ok_vol  = not useSqueezeFilter or not sqz_on
    bool active  = not na(ma_val) and not na(band_abs) and ok_date and ok_vol

    if active
        if side == 0
            if close > upper
                side := 1
            else if close < lower
                side := -1
        else
            bool far       = side > 0 ? close < lower  : close > upper
            bool far_line  = side > 0 ? close < ma_val : close > ma_val
            bool at_origin = side > 0 ? close > upper  : close < lower

            bool broke = false
            if far
                if opp_run == 0
                    opp_idx := bar_index
                opp_run += 1
                if opp_run >= 2
                    cBk := cBk + 1
                    cT  := cT + 1
                    broke := true
                    if dbg
                        log.info(lbl + " | BREAK  | " + str.format_time(time, "yyyy-MM-dd", syminfo.timezone) + " total=" + str.tostring(cT))
                    side := -side
                    opp_run := 0
            else
                if opp_run == 1
                    cF := cF + 1
                    cT := cT + 1
                    if dbg
                        log.info(lbl + " | FALSE  | " + str.format_time(time, "yyyy-MM-dd", syminfo.timezone) + " total=" + str.tostring(cT))
                opp_run := 0

            if broke
                in_appr          := false
                appr_crossed_far := false
                appr_below_line  := false
                need_origin      := true
            else
                if at_origin
                    need_origin := false
                    if in_appr and not appr_crossed_far
                        cB := cB + 1
                        cT := cT + 1
                        if dbg
                            log.info(lbl + " | BOUNCE | " + str.format_time(time, "yyyy-MM-dd", syminfo.timezone) + " total=" + str.tostring(cT))
                    in_appr          := false
                    appr_crossed_far := false
                    appr_below_line  := false

                bool fresh = touched and not prev_touched
                if touched and not need_origin
                    if fresh and not in_appr
                        in_appr          := true
                        appr_idx         := bar_index
                        appr_crossed_far := far
                        appr_below_line  := far_line
                    else if in_appr
                        if far
                            appr_crossed_far := true
                        if far_line
                            appr_below_line := true

                if in_appr and not appr_crossed_far and appr_below_line and not far_line and not at_origin
                    cB := cB + 1
                    cT := cT + 1
                    if dbg
                        log.info(lbl + " | BOUNCE | " + str.format_time(time, "yyyy-MM-dd", syminfo.timezone) + " total=" + str.tostring(cT))
                    in_appr         := false
                    appr_below_line := false
                    need_origin     := true

        prev_touched := touched

    [cT, cB, cBk, cF]

// CSV helper — joins one (T, B, Bk, F) tuple with commas.
fmt4(int t, int b, int k, int f) =>
    str.tostring(t) + "," + str.tostring(b) + "," + str.tostring(k) + "," + str.tostring(f)

// Memory-saving wrapper around run_sm. When `active` is false, the inner
// var-bearing state machine is never invoked — Pine never allocates the
// history buffers for its [1] references on this call site, slashing memory.
// Returns zeros so the CSV output cleanly marks the slot as "not in this pass".
run_sm_gated(bool active, float ma_val, bool sqz_on, float band_abs, bool dbg, string lbl) =>
    int t = 0
    int b = 0
    int k = 0
    int f = 0
    if active
        [_t, _b, _k, _f] = run_sm(ma_val, sqz_on, band_abs, dbg, lbl)
        t := _t
        b := _b
        k := _k
        f := _f
    [t, b, k, f]

// ==========================================
// 4. WRAPPER — calcula squeeze + 5 MAs × 5 tols = 25 state machines por ticker
// ==========================================
// Returns a single CSV string with 100 ints (tol_idx outer × ma_idx middle × metric inner).
// Order: t0m0_T, t0m0_B, t0m0_Bk, t0m0_F, t0m1_T, ..., t0m4_F, t1m0_T, ..., t4m4_F.
// Returning a string (instead of a 100-tuple) keeps request.security boilerplate
// to one line per ticker and the DIRECT-fallback override to one line per ticker.
run_full() =>
    [_, ub, lb] = ta.bb(close, 20, 2.0)
    bk  = ta.sma(close, 20)
    rk  = ta.tr(true)
    ark = ta.sma(rk, 20)
    ukc = bk + ark * 1.5
    lkc = bk - ark * 1.5
    bool sqz = (ub < ukc) and (lb > lkc)

    ma1 = ta.ema(close, ema_fast_p)
    ma2 = ta.ema(close, ema_slow_p)
    ma3 = ta.sma(close, sma_mid_p)
    ma4 = ta.sma(close, sma_long_p)
    ma5 = ta.vwap
    ma6 = ub   // Bollinger Upper (20, 2σ) — reuses ub from the squeeze calc above
    ma7 = lb   // Bollinger Lower (20, 2σ)

    // v15 BAND-ZONE: single ATR band (0.2*ATR by default), the SAME width for every level. ATR is
    // computed in THIS security context, so the band auto-scales per ticker/TF. get_tol_grid below is
    // kept ONLY to mask skipped cells (VWAP on D/W etc.): where its value is 0, the cell is zeroed.
    float atrB = kBand * ta.atr(bandN)

    [g1_0, g1_1, g1_2, g1_3, g1_4] = get_tol_grid(0)
    [g2_0, g2_1, g2_2, g2_3, g2_4] = get_tol_grid(1)
    [g3_0, g3_1, g3_2, g3_3, g3_4] = get_tol_grid(2)
    [g4_0, g4_1, g4_2, g4_3, g4_4] = get_tol_grid(3)
    [g5_0, g5_1, g5_2, g5_3, g5_4] = get_tol_grid(4)
    [g6_0, g6_1, g6_2, g6_3, g6_4] = get_tol_grid(5)
    [g7_0, g7_1, g7_2, g7_3, g7_4] = get_tol_grid(6)

    bool is_dbg_t = dbgEnable and syminfo.ticker == dbgTicker
    bool dbg_m1   = is_dbg_t and dbgMA == "EMA9"
    bool dbg_m2   = is_dbg_t and dbgMA == "EMA20"
    bool dbg_m3   = is_dbg_t and dbgMA == "SMA50"
    bool dbg_m4   = is_dbg_t and dbgMA == "SMA200"
    bool dbg_m5   = is_dbg_t and dbgMA == "VWAP"
    bool dbg_m6   = is_dbg_t and dbgMA == "BBu"
    bool dbg_m7   = is_dbg_t and dbgMA == "BBl"

    // Run state machine: 5 MAs × 5 tols = up to 25 calls per ticker. The
    // gated wrapper SKIPS the inner state machine when the slice is inactive,
    // so Pine never allocates history buffers for those call sites. This is
    // how 'Memory Saver — A/B/C' fits the run inside Pine's memory budget.
    int m1T_0 = 0
    int m1B_0 = 0
    int m1K_0 = 0
    int m1F_0 = 0
    int m1T_1 = 0
    int m1B_1 = 0
    int m1K_1 = 0
    int m1F_1 = 0
    [m1T_2, m1B_2, m1K_2, m1F_2] = run_sm(ma1, sqz, g1_2 > 0 ? atrB : 0.0001, dbg_m1 and dbgTolIdx == 2, "EMA9[2]")
    int m1T_3 = 0
    int m1B_3 = 0
    int m1K_3 = 0
    int m1F_3 = 0
    int m1T_4 = 0
    int m1B_4 = 0
    int m1K_4 = 0
    int m1F_4 = 0

    int m2T_0 = 0

    int m2B_0 = 0

    int m2K_0 = 0

    int m2F_0 = 0
    int m2T_1 = 0
    int m2B_1 = 0
    int m2K_1 = 0
    int m2F_1 = 0
    [m2T_2, m2B_2, m2K_2, m2F_2] = run_sm(ma2, sqz, g2_2 > 0 ? atrB : 0.0001, dbg_m2 and dbgTolIdx == 2, "EMA20[2]")
    int m2T_3 = 0
    int m2B_3 = 0
    int m2K_3 = 0
