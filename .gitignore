# ── Credenciais e segredos ────────────────────────────────────────────────────
.env
.env.local
*.key
*.pem
.credentials/
!.credentials/.gitkeep

# ── Dados de mercado (Google Drive / local — nunca no repo) ──────────────────
*.parquet
data/
!data/.gitkeep
!data/**/.gitkeep

# ── State (histórico GEX é tracked; caches locais não) ──────────────────────
state/**/*.cache.json
state/**/*.tmp

# ── Relatórios gerados (logs e imagens — CSVs são commitados p/ viewer) ─────
reports/**/*.log
reports/**/*.png
reports/**/performance_report.txt
reports/**/*.parquet

# ── Artefatos de sessão (Claude Code, Codex, etc) ───────────────────────────
*-this-session-is-being-continued-*.txt
.archive/

# ── Python cache ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.egg-info/
build/
dist/

# ── Ambiente virtual ─────────────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE e OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini

# ── Infra / Cloud ────────────────────────────────────────────────────────────
infra/rclone.conf

# ── Claude Code (interno pessoal; skills/agents do projeto SAO tracked) ─────
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/project/
!.claude/agents/
.claude/agents/*
!.claude/agents/project/
